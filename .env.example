# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers > OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Auth callback URL (must match GitHub OAuth App settings)
# Development: http://localhost:3000/auth/callback
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# ── GitLab OAuth App ──────────────────────────────────────────────────────────
# Create at: https://gitlab.com/-/user_settings/applications
# Scopes required: read_api read_user read_repository
# Redirect URI: http://localhost:3000/auth/gitlab/callback
GITLAB_CLIENT_ID=your_gitlab_application_id
GITLAB_CLIENT_SECRET=your_gitlab_secret
GITLAB_REDIRECT_URI=http://localhost:3000/auth/gitlab/callback

# ── Auth & Security ───────────────────────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://codepulse:codepulse@localhost:5432/codepulse

# ── Next.js public vars ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
NEXT_PUBLIC_GITLAB_CLIENT_ID=your_gitlab_application_id
